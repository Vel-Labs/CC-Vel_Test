# Required for real Claude Sonnet runs.
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key

# Defaults to the current Sonnet model ID from Anthropic docs.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Set to 1 to avoid writing .skill-usage/ledger.jsonl during local experimentation.
MINI_AGENT_DISABLE_LEDGER=0
